{
  "version": 1,
  "questions": [
    {
      "id": "curl_pattern",
      "prompt": "Which photo looks most like your hair when it's clean and dry?",
      "type": "single_image",
      "maps_to": "type",
      "options": [
        {"id": "1A", "label": "Straight (fine)", "image": "/curl-types/1a.jpg"},
        {"id": "1B", "label": "Straight (medium)", "image": "/curl-types/1b.jpg"},
        {"id": "1C", "label": "Straight (coarse)", "image": "/curl-types/1c.jpg"},
        {"id": "2A", "label": "Loose wave", "image": "/curl-types/2a.jpg"},
        {"id": "2B", "label": "Wave", "image": "/curl-types/2b.jpg"},
        {"id": "2C", "label": "Defined wave", "image": "/curl-types/2c.jpg"},
        {"id": "3A", "label": "Loose curl", "image": "/curl-types/3a.jpg"},
        {"id": "3B", "label": "Curl", "image": "/curl-types/3b.jpg"},
        {"id": "3C", "label": "Tight curl", "image": "/curl-types/3c.jpg"},
        {"id": "4A", "label": "Coily (soft)", "image": "/curl-types/4a.jpg"},
        {"id": "4B", "label": "Coily (zigzag)", "image": "/curl-types/4b.jpg"},
        {"id": "4C", "label": "Coily (tight)", "image": "/curl-types/4c.jpg"}
      ]
    },
    {
      "id": "scalp_condition",
      "prompt": "Which best describes your scalp most days?",
      "type": "single",
      "maps_to": "scalp_condition",
      "options": [
        {"id": "oily", "label": "Feels oily or greasy"},
        {"id": "dry", "label": "Feels tight or dry"},
        {"id": "flaky", "label": "Itchy or flaky (dandruff)"},
        {"id": "sensitive", "label": "Sensitive or easily irritated"},
        {"id": "balanced", "label": "Feels balanced / normal"}
      ]
    },
    {
      "id": "density",
      "prompt": "When your hair is loose, how much of your scalp can you see?",
      "type": "single",
      "maps_to": "density",
      "options": [
        {"id": "thin", "label": "Mostly visible — large gaps"},
        {"id": "medium", "label": "Some scalp visible in places"},
        {"id": "thick", "label": "Barely visible — full coverage"}
      ]
    },
    {
      "id": "strand_thickness",
      "prompt": "How do individual strands feel between your fingers?",
      "type": "single",
      "maps_to": "strand_thickness",
      "options": [
        {"id": "fine", "label": "Very fine / thin"},
        {"id": "medium", "label": "Medium / normal"},
        {"id": "coarse", "label": "Thick / coarse"}
      ]
    },
    {
      "id": "chemical_history",
      "prompt": "Have you ever chemically treated your hair? (select all that apply)",
      "type": "multi",
      "maps_to": "chemical_history",
      "options": [
        {"id": "bleach", "label": "Bleach or highlights"},
        {"id": "color", "label": "Permanent color / dye"},
        {"id": "relaxer", "label": "Permanent straightening / relaxer"},
        {"id": "keratin", "label": "Keratin / acid smoothing"},
        {"id": "none", "label": "No chemical treatments"}
      ]
    },
    {
      "id": "chemical_recency",
      "prompt": "When was your most recent chemical service?",
      "type": "single",
      "maps_to": "chemical_recency",
      "conditional_on": {"question_id": "chemical_history", "value_not_in": ["none"]},
      "skip_value": "na",
      "options": [
        {"id": "within_1mo", "label": "Within the last month"},
        {"id": "1_3mo", "label": "1–3 months ago"},
        {"id": "3_6mo", "label": "3–6 months ago"},
        {"id": "6plus", "label": "6+ months ago"}
      ]
    },
    {
      "id": "heat_frequency",
      "prompt": "How often do you use heat tools (blow dryer, flat iron, curling iron)?",
      "type": "single",
      "maps_to": "heat_frequency",
      "options": [
        {"id": "daily", "label": "Daily"},
        {"id": "weekly", "label": "A few times a week"},
        {"id": "rare", "label": "Rarely"},
        {"id": "never", "label": "Never"}
      ]
    },
    {
      "id": "concerns",
      "prompt": "What are your top hair concerns right now? (pick up to 3)",
      "type": "multi",
      "max_select": 3,
      "maps_to": "concerns",
      "options": [
        {"id": "frizz", "label": "Frizz"},
        {"id": "breakage", "label": "Breakage / split ends"},
        {"id": "thinning", "label": "Thinning / hair loss"},
        {"id": "dandruff", "label": "Dandruff / flakes"},
        {"id": "dryness", "label": "Dryness / lack of moisture"},
        {"id": "dullness", "label": "Dullness / no shine"},
        {"id": "flatness", "label": "Lack of volume"},
        {"id": "irritation", "label": "Scalp irritation"}
      ]
    },
    {
      "id": "goal",
      "prompt": "What's your main goal for your hair right now?",
      "type": "single",
      "maps_to": "goals",
      "wrap_in_list": true,
      "options": [
        {"id": "definition", "label": "More definition / curl shape"},
        {"id": "volume", "label": "More volume"},
        {"id": "strength", "label": "Stronger / less breakage"},
        {"id": "length", "label": "Grow longer / length retention"},
        {"id": "scalp_health", "label": "Healthier scalp"},
        {"id": "shine", "label": "More shine"}
      ]
    },
    {
      "id": "product_absorption",
      "prompt": "When you put oil or a leave-in on a section of hair, what happens?",
      "type": "single",
      "maps_to": "product_absorption",
      "options": [
        {"id": "soaks", "label": "It soaks in quickly"},
        {"id": "sits", "label": "It mostly sits on top"},
        {"id": "greasy", "label": "Hair gets greasy quickly"},
        {"id": "unsure", "label": "I can't tell"}
      ]
    },
    {
      "id": "wash_frequency",
      "prompt": "How often do you wash your hair?",
      "type": "single",
      "maps_to": "wash_frequency",
      "options": [
        {"id": "daily", "label": "Daily"},
        {"id": "2_3_days", "label": "Every 2–3 days"},
        {"id": "weekly", "label": "Once a week"},
        {"id": "less", "label": "Less than once a week"}
      ]
    },
    {
      "id": "climate",
      "prompt": "What's the climate like where you live most of the year?",
      "type": "single",
      "maps_to": "climate",
      "options": [
        {"id": "humid", "label": "Humid"},
        {"id": "dry", "label": "Dry / low humidity"},
        {"id": "cold", "label": "Cold"},
        {"id": "mixed", "label": "Mixed / seasonal"}
      ]
    },
    {
      "id": "styling_time",
      "prompt": "How much time do you spend styling each day?",
      "type": "single",
      "maps_to": "styling_time",
      "options": [
        {"id": "under_10", "label": "Under 10 minutes"},
        {"id": "10_30", "label": "10–30 minutes"},
        {"id": "30plus", "label": "30+ minutes"}
      ]
    }
  ]
}
