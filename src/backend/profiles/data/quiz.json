{
  "version": 9,
  "questions": [
    {
      "id": "curl_pattern",
      "prompt": "Which photo looks most like your hair?",
      "type": "single_image",
      "maps_to": "curl_pattern",
      "options": [
        {"id": "straight", "label": "Straight", "image": "/hair-types/straight.png"},
        {"id": "wavy", "label": "Wavy", "image": "/hair-types/wavy.png"},
        {"id": "curly", "label": "Curly", "image": "/hair-types/curly.png"},
        {"id": "coily", "label": "Coily", "image": "/hair-types/coily.png"}
      ]
    },
    {
      "id": "scalp_condition",
      "prompt": "Which best describes your scalp most days?",
      "type": "single",
      "maps_to": "scalp_condition",
      "options": [
        {"id": "oily", "label": "Oily"},
        {"id": "dry", "label": "Dry"},
        {"id": "flaky", "label": "Flaky"},
        {"id": "sensitive", "label": "Sensitive"},
        {"id": "balanced", "label": "Balanced"}
      ]
    },
    {
      "id": "density",
      "prompt": "When your hair is loose, how much of your scalp can you see?",
      "type": "single",
      "maps_to": "density",
      "options": [
        {"id": "thin", "label": "Mostly visible"},
        {"id": "medium", "label": "Somewhat visible"},
        {"id": "thick", "label": "Barely visible"}
      ]
    },
    {
      "id": "strand_thickness",
      "prompt": "How do individual strands feel between your fingers?",
      "type": "single",
      "maps_to": "strand_thickness",
      "options": [
        {"id": "fine", "label": "Fine"},
        {"id": "medium", "label": "Medium"},
        {"id": "coarse", "label": "Coarse"}
      ]
    },
    {
      "id": "chemical_treatment",
      "prompt": "Have you used any chemical treatments on your hair recently?",
      "type": "single",
      "maps_to": "chemical_treatment",
      "options": [
        {"id": "none", "label": "None"},
        {"id": "color_treated", "label": "Color (semi or permanent dye)"},
        {"id": "bleached_highlighted", "label": "Bleach or highlights"},
        {"id": "relaxed_or_permed", "label": "Relaxer or perm"},
        {"id": "multiple", "label": "Multiple of the above"}
      ]
    },
    {
      "id": "heat_tool_frequency",
      "prompt": "How often do you use hot tools (blow dryer, flat iron, curling wand)?",
      "type": "single",
      "maps_to": "heat_tool_frequency",
      "options": [
        {"id": "never", "label": "Never"},
        {"id": "occasional", "label": "Occasionally (less than once a week)"},
        {"id": "weekly", "label": "About once a week"},
        {"id": "frequent", "label": "Several times a week or daily"}
      ]
    },
    {
      "id": "concerns",
      "prompt": "What are your main hair concerns?",
      "type": "multi",
      "max_select": 3,
      "maps_to": "concerns",
      "options": [
        {"id": "frizz", "label": "Frizziness"},
        {"id": "breakage", "label": "Breakage"},
        {"id": "thinning", "label": "Thinning"},
        {"id": "dandruff", "label": "Dandruff"},
        {"id": "dryness", "label": "Dryness"},
        {"id": "dullness", "label": "Dullness"},
        {"id": "flatness", "label": "Flatness"},
        {"id": "irritation", "label": "Scalp irritation"}
      ]
    },
    {
      "id": "goal",
      "prompt": "What is your main hair goal?",
      "type": "single",
      "maps_to": "goals",
      "wrap_in_list": true,
      "options": [
        {"id": "definition", "label": "Define my curls"},
        {"id": "volume", "label": "More volume"},
        {"id": "strength", "label": "Repair damage"},
        {"id": "length", "label": "Grow longer"},
        {"id": "scalp_health", "label": "Healthier scalp"},
        {"id": "shine", "label": "More shine"}
      ]
    },
    {
      "id": "product_absorption",
      "prompt": "When you put oil or a leave-in on a section of hair, what happens?",
      "type": "single",
      "maps_to": "product_absorption",
      "options": [
        {"id": "soaks", "label": "It soaks in quickly"},
        {"id": "medium", "label": "It absorbs evenly without sitting or soaking"},
        {"id": "sits", "label": "It mostly sits on top"},
        {"id": "greasy", "label": "Hair gets greasy quickly"},
        {"id": "unsure", "label": "I can't tell"}
      ]
    },
    {
      "id": "wash_frequency",
      "prompt": "How often do you wash your hair?",
      "type": "single",
      "maps_to": "wash_frequency",
      "options": [
        {"id": "daily", "label": "Daily"},
        {"id": "2_3_days", "label": "Every 2–3 days"},
        {"id": "weekly", "label": "Once a week"},
        {"id": "less", "label": "Less than once a week"}
      ]
    },
    {
      "id": "climate",
      "prompt": "What's the climate like where you live most of the year?",
      "type": "single",
      "maps_to": "climate",
      "options": [
        {"id": "humid", "label": "Humid"},
        {"id": "dry", "label": "Dry / low humidity"},
        {"id": "cold", "label": "Cold"},
        {"id": "mixed", "label": "Mixed / seasonal"}
      ]
    },
    {
      "id": "story",
      "prompt": "Anything else worth knowing? (Optional)",
      "type": "text",
      "maps_to": "story",
      "placeholder": "e.g. sulfates burn my scalp",
      "max_length": 800,
      "optional": true,
      "options": []
    }
  ]
}
